# Server Port configuration
PORT=5000

# MongoDB Connection String (Atlas production or local)
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# JWT Token configuration (Must be secure random strings in production)
JWT_SECRET=YOUR_SECURE_JWT_ACCESS_SECRET
JWT_REFRESH_SECRET=YOUR_SECURE_JWT_REFRESH_SECRET
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Customer Support contact details
SUPPORT_PHONE=7506710665
SUPPORT_WHATSAPP=7506710665

# App specifications
APP_NAME=Naukari Bazaar
APP_VERSION=1.0.0
NODE_ENV=development
